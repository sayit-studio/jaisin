{
  "type": "flex",
  "altText": "宅心驗屋 LIFF 分享測試",
  "contents": {
    "type": "bubble",
    "size": "mega",
    "hero": {
      "type": "image",
      "url": "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=1200&q=80",
      "size": "full",
      "aspectRatio": "20:13",
      "aspectMode": "cover"
    },
    "body": {
      "type": "box",
      "layout": "vertical",
      "spacing": "md",
      "contents": [
        {
          "type": "text",
          "text": "宅心驗屋分享測試",
          "weight": "bold",
          "size": "xl",
          "color": "#17221F"
        },
        {
          "type": "text",
          "text": "這是一則 LIFF Share Target Picker 測試訊息，會以完整 Flex Message 格式分享給好友。",
          "wrap": true,
          "size": "sm",
          "color": "#3C4B45"
        },
        {
          "type": "box",
          "layout": "vertical",
          "margin": "lg",
          "spacing": "sm",
          "contents": [
            {
              "type": "box",
              "layout": "baseline",
              "spacing": "sm",
              "contents": [
                {
                  "type": "text",
                  "text": "來源",
                  "color": "#6B7280",
                  "size": "sm",
                  "flex": 2
                },
                {
                  "type": "text",
                  "text": "{{ref}}",
                  "wrap": true,
                  "color": "#17221F",
                  "size": "sm",
                  "flex": 5
                }
              ]
            },
            {
              "type": "box",
              "layout": "baseline",
              "spacing": "sm",
              "contents": [
                {
                  "type": "text",
                  "text": "活動",
                  "color": "#6B7280",
                  "size": "sm",
                  "flex": 2
                },
                {
                  "type": "text",
                  "text": "{{campaign}}",
                  "wrap": true,
                  "color": "#17221F",
                  "size": "sm",
                  "flex": 5
                }
              ]
            }
          ]
        }
      ]
    },
    "footer": {
      "type": "box",
      "layout": "vertical",
      "spacing": "sm",
      "contents": [
        {
          "type": "button",
          "style": "primary",
          "color": "#1B6F58",
          "action": {
            "type": "uri",
            "label": "轉發給好友",
            "uri": "{{shareUrl}}"
          }
        },
        {
          "type": "button",
          "style": "link",
          "action": {
            "type": "uri",
            "label": "預約驗屋諮詢",
            "uri": "{{bookingUrl}}"
          }
        }
      ],
      "flex": 0
    }
  }
}
